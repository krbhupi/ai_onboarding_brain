# Application Settings
APP_NAME=HR Automation - AI Onboarding
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
# SQLite (for development)
DATABASE_URL=sqlite+aiosqlite:///./hr_onboarding.db
# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hr_onboarding
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Email - IMAP Configuration (Gmail)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=True

# Email - SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_FROM_EMAIL=your-email@gmail.com

# OAuth2 Configuration (for Outlook - optional)
USE_OAUTH2=false
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# LLM Configuration (Ollama Cloud)
LLM_BASE_URL=https://ollama.com
LLM_MODEL=gpt-oss:120b
LLM_TIMEOUT=120
OLLAMA_API_KEY=your-ollama-api-key

# Vision LLM Configuration
# Options: local_ollama, ocr_fallback
VISION_BACKEND=ocr_fallback
VISION_MODEL=llava:13b
# For local Ollama: http://localhost:11434
# VISION_BASE_URL=http://localhost:11434

# File Storage Paths
DOCUMENT_STORAGE_PATH=./data/documents
TEMP_STORAGE_PATH=./data/temp

# Excel Tracker Path
EXCEL_TRACKER_PATH=./data/input/offer_tracker.xlsx

# Airflow Settings
AIRFLOW_DAG_ID=hr_onboarding_etl
AIRFLOW_SCHEDULE=0 22 * * *

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30